{
  "name": "fintech-payment-api",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:worker": "npm run dev --workspace=apps/worker",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "migrate": "dotenv -e .env -- ts-node --transpile-only --project packages/shared/tsconfig.json packages/shared/src/db/migrate.ts",
    "build:api": "npm run build --workspace=packages/shared && npm run build --workspace=apps/api",
    "build:worker": "npm run build --workspace=packages/shared && npm run build --workspace=apps/worker",
    "start:api": "node apps/api/dist/server.js",
    "start:worker": "node apps/worker/dist/worker.js"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}
